{
  "type": "hysteria2",
  "tag": "proxy",
  "server": "{{.Endpoint.Host}}",
  "server_port": {{.Endpoint.Port}},
  "up_mbps": 50,
  "down_mbps": 100,
  "password": "{{.Credentials.Password}}",
  "obfs": {
    "type": "salamander",
    "password": "{{.Credentials.ObfsPassword}}"
  },
  "tls": {
    "enabled": true,
    "server_name": "{{.Credentials.SNI}}",
    "insecure": false
  }
}
