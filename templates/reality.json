{
  "type": "vless",
  "tag": "proxy",
  "server": "{{.Endpoint.Host}}",
  "server_port": {{.Endpoint.Port}},
  "uuid": "{{.Credentials.UUID}}",
  "flow": "xtls-rprx-vision",
  "packet_encoding": "xudp",
  "tls": {
    "enabled": true,
    "server_name": "{{.Credentials.SNI}}",
    "utls": {
      "enabled": true,
      "fingerprint": "{{.Credentials.UTLSFingerprint}}"
    },
    "reality": {
      "enabled": true,
      "public_key": "{{.Credentials.PublicKey}}",
      "short_id": "{{.Credentials.ShortID}}"
    }
  },
  "multiplex": {
    "enabled": true,
    "protocol": "smux",
    "padding": true,
    "brutal_capacity": 100
  }
}
