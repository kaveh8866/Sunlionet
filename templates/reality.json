{
  "type": "vless",
  "tag": "reality-out",
  "server": "{{.ServerIP}}",
  "server_port": "{{.ServerPort}}",
  "uuid": "{{.UUID}}", 
  "flow": "xtls-rprx-vision",
  "packet_encoding": "xudp",
  "tls": {
    "enabled": true,
    "server_name": "{{.SNI}}",
    "utls": {
      "enabled": true,
      "fingerprint": "{{.UTLS}}"
    },
    "reality": {
      "enabled": true,
      "public_key": "{{.PubKey}}",
      "short_id": "{{.ShortID}}"
    }
  },
  "multiplex": {
    "enabled": true,
    "protocol": "smux",
    "padding": true,
    "brutal_capacity": 100
  }
}
